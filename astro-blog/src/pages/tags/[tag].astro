---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = new Set(posts.flatMap((post) => post.data.tags));

  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    }
  }));
}

const { tag, posts } = Astro.props;
const tagHref = (tagName: string) => `/tags/${encodeURIComponent(tagName)}/`;
---

<BaseLayout title={`#${tag}`} description={`查看 #${tag} 标签下的所有文章。`}>
  <section class="article">
    <header>
      <p class="eyebrow">标签</p>
      <h1>#{tag}</h1>
      <p class="lead">共 {posts.length} 篇文章。</p>
    </header>
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-card">
          <article>
            <div class="meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('zh-CN')}
              </time>
              {post.data.tags.map((tagName) => (
                <a class="tag" href={tagHref(tagName)}>#{tagName}</a>
              ))}
            </div>
            <h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
          </article>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
